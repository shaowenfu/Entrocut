{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Core (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/core/venv/bin/python",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/core",
      "args": [
        "server:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug Server (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/server/venv/bin/python",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/server",
      "args": [
        "main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8001",
        "--reload"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug Client (Electron)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/client",
      "runtimeExecutable": "${workspaceFolder}/client/node_modules/electron/dist/electron",
      "args": [
        "--remote-debugging-port=9222",
        "${workspaceFolder}/client/dist-electron/main.js"
      ],
      "preLaunchTask": "Client: Start Dev Prerequisites",
      "console": "integratedTerminal",
      "outputCapture": "std",
      "outFiles": [
        "${workspaceFolder}/client/dist-electron/**/*.js",
        "${workspaceFolder}/client/dist-electron/**/*.cjs"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
