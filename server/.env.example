APP_ENV=local
SERVER_PORT=8001
SERVER_LOG_LEVEL=info
SERVER_BASE_URL=http://127.0.0.1:8001
OBSERVABILITY_ENABLE_METRICS=true
ALLOW_INMEMORY_MONGO_FALLBACK=true
ALLOW_INMEMORY_REDIS_FALLBACK=true
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=entrocut_server
REDIS_URL=redis://127.0.0.1:6379/0
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_SECRET=entrocut-dev-secret-change-me
AUTH_ACCESS_TOKEN_EXPIRES_SECONDS=3600
AUTH_REFRESH_TOKEN_EXPIRES_SECONDS=2592000
AUTH_LOGIN_SESSION_TTL_SECONDS=600
AUTH_DEEP_LINK_SCHEME=entrocut
AUTH_TOKEN_ISSUER=entrocut-server
AUTH_TOKEN_AUDIENCE=entrocut-core
AUTH_DEV_FALLBACK_ENABLED=true
AUTH_DEV_FALLBACK_WEB_URL=http://127.0.0.1:5173/
STAGING_TEST_BOOTSTRAP_ENABLED=false
STAGING_TEST_BOOTSTRAP_SECRET=
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_SCOPE=openid email profile
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
GOOGLE_API_KEY=

# DashScope MultiModal Embedding
DASHSCOPE_API_KEY=
DASHSCOPE_MULTIMODAL_EMBEDDING_MODEL=qwen3-vl-embedding
DASHSCOPE_MULTIMODAL_DIMENSION=1024

# DashVector
DASHVECTOR_API_KEY=
DASHVECTOR_ENDPOINT=
DASHVECTOR_COLLECTION_NAME=entrocut_assets
DASHVECTOR_PARTITION=default
DASHVECTOR_TIMEOUT_SECONDS=10
DASHVECTOR_PROTOCOL=grpc
