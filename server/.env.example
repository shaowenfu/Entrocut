# ============================================
# Entrocut Server 环境变量配置示例
# ============================================
#
# 使用方法：
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 根据实际情况修改配置值
#   3. 确保 .env 文件已在 .gitignore 中（不要提交到仓库）
#
# 本地开发：可使用默认值或按需修改
# 生产部署：通过 GitHub Secrets 注入（推荐）
#

# ============================================
# 基础服务配置（必需）
# ============================================

# 服务监听端口
# 默认: 8001
SERVER_PORT=8001

# 日志级别
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 生产环境建议: INFO
LOG_LEVEL=INFO

# API 契约版本
# 用于客户端和服务端契约协商
# 当前版本: 0.1.0-mock (MVP 阶段)
CONTRACT_VERSION=0.1.0-mock

# 运行环境
# 可选值: development, production
# development: 启用详细日志和 CORS 允许所有来源
# production: 使用生产级日志和受限 CORS
ENVIRONMENT=development

# ============================================
# 阿里云服务配置（后续阶段使用）
# ============================================

# DashScope API Key (通义千问)
# 用途: AI 视频分析、场景识别
# 获取: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DashVector 配置
# 用途: 向量数据库，存储视频特征向量
# 获取: https://dashvector.console.aliyun.com/
DASHVECTOR_API_KEY=your_dashvector_api_key_here
DASHVECTOR_ENDPOINT=https://dashvector.cn-hangzhou.aliyuncs.com

# ============================================
# MongoDB 配置（后续阶段使用）
# ============================================

# MongoDB 连接字符串和数据库（dev和main都是单独的MongoDB atlas cluster）
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=entrocut

# ============================================
# 认证配置（后续阶段使用）
# ============================================

# JWT 密钥（用于生成和验证访问令牌）
# 生产环境: 必须使用强随机字符串（至少 32 字符）
# 生成方法: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here

# JWT 算法
# 默认: HS256
JWT_ALGORITHM=HS256

# JWT 过期时间（分钟）
# 默认: 60 分钟
JWT_EXPIRE_MINUTES=60

# ============================================
# CORS 配置（可选）
# ============================================

# 允许的跨域来源（逗号分隔）
# 生产环境应指定具体域名，开发环境可用 *
CORS_ORIGINS=*

# ============================================
# 部署说明
# ============================================
#
# 本地开发:
#   1. cp .env.example .env
#   2. 修改需要变更的值
#   3. 激活虚拟环境后使用python -m uvicorn main:app
#
# Docker 运行:
#   docker run -e SERVER_PORT=8001 -e LOG_LEVEL=INFO ...
#   (不使用 .env 文件，直接通过 -e 参数传入)
#
# ECS 部署:
#   环境变量通过 GitHub Secrets 在 CI/CD 中注入
#   不需要在 ECS 上维护 .env 文件
#
# ============================================
# 安全提醒
# ============================================
#
# 1. .env 文件包含敏感信息，切勿提交到 Git 仓库
# 2. 生产环境密钥应定期轮换
# 3. 不同环境（开发/测试/生产）使用不同的密钥
# 4. 日志中不应输出完整的密钥或 Token
