# ===========================================
# Entrocut 环境变量配置模板
# ===========================================

# -------------------------------------------
# 阿里云 DashScope (通义千问 API)
# -------------------------------------------
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# -------------------------------------------
# 阿里云 DashVector (向量数据库)
# -------------------------------------------
DASHVECTOR_API_KEY=your_dashvector_api_key_here
DASHVECTOR_ENDPOINT=your_dashvector_endpoint_here
DASHVECTOR_COLLECTION_NAME=entrocut_frames

# -------------------------------------------
# MongoDB (文档数据库)
# -------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=entrocut

# -------------------------------------------
# 服务端口配置
# -------------------------------------------
CORE_PORT=8000          # 本地算法 Sidecar 端口
SERVER_PORT=8001        # 云端 Backend 端口
CLIENT_PORT=5173        # Vite 开发服务器端口

# -------------------------------------------
# Electron 配置
# -------------------------------------------
ELECTRON_IS_DEV=true
